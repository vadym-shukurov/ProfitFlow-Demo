# ════════════════════════════════════════════════════════════════════════════
# ProfitFlow — Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Used by both docker-compose.yml and the Spring Boot datasource.
POSTGRES_DB=profitflow
POSTGRES_USER=profitflow
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Spring Boot datasource (can differ from docker-compose values in prod) ───
DB_URL=jdbc:postgresql://localhost:5432/profitflow
DB_USERNAME=profitflow
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── CORS (set to your production domain, e.g. https://app.company.com) ───────
ALLOWED_ORIGINS=http://localhost:4200

# ── RSA signing keys for JWT ─────────────────────────────────────────────────
# In production, mount these from a secrets manager (Vault, AWS Secrets Manager)
# rather than from the filesystem. The private key MUST remain secret.
#
# The default paths below point to the development keys in src/main/resources/certs/.
# Generate production keys with:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
#
# To override the classpath defaults, set these to absolute file:// URLs:
# RSA_PRIVATE_KEY=file:/run/secrets/jwt-private.pem
# RSA_PUBLIC_KEY=file:/run/secrets/jwt-public.pem

# ── OpenAPI / SpringDoc ─────────────────────────────────────────────────────
# Leave false (default). Anonymous /v3/api-docs is only enabled via the openapi-export
# profile YAML for CI contract export — never set OPENAPI_UNAUTHENTICATED_ACCESS=true in prod.
# OPENAPI_UNAUTHENTICATED_ACCESS=false
