<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  Checkstyle configuration for ProfitFlow.

  Based on Google Java Style with the following finance-specific additions:
  - Javadoc required on all public methods with a business/domain impact
  - Magic numbers banned in domain and service layers
  - Line length 120 (wider than Google's 100 to accommodate verbose financial API types)
-->
<module name="Checker">
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <!-- ── File-level checks ─────────────────────────────────────────── -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>
    <module name="NewlineAtEndOfFile"/>

    <!-- Trailing whitespace causes noisy diffs in code reviews -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="message" value="Line has trailing whitespace."/>
    </module>

    <module name="TreeWalker">
        <!-- ── Imports ───────────────────────────────────────────────── -->
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
        <module name="AvoidStarImport"/>
        <module name="IllegalImport">
            <!-- Ban sun.* and com.sun.* — internal JDK APIs, not part of the public spec -->
            <property name="illegalPkgs" value="sun, com.sun"/>
        </module>

        <!-- ── Naming conventions ────────────────────────────────────── -->
        <module name="TypeName"/>
        <module name="MethodName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
        <module name="ParameterName"/>
        <!-- SLF4J loggers are conventionally named lowercase 'log' in Java;
             the standard ConstantName rule is relaxed to allow it. -->
        <module name="ConstantName">
            <property name="format" value="^log$|^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- ── Whitespace ────────────────────────────────────────────── -->
        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
        </module>
        <module name="NoWhitespaceBefore"/>
        <module name="GenericWhitespace"/>

        <!-- ── Braces & blocks ───────────────────────────────────────── -->
        <module name="NeedBraces"/>
        <module name="LeftCurly"/>
        <module name="RightCurly"/>
        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>

        <!-- ── Coding style ──────────────────────────────────────────── -->
        <module name="EqualsHashCode"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <module name="StringLiteralEquality"/>
        <module name="DefaultComesLast"/>
        <module name="FallThrough"/>
        <module name="MultipleVariableDeclarations"/>
        <module name="OneStatementPerLine"/>
        <module name="UnnecessaryParentheses"/>

        <!-- ── Complexity ────────────────────────────────────────────── -->
        <!-- Finance logic can be complex; thresholds are deliberately
             higher than defaults to avoid flagging legitimate algorithms. -->
        <module name="CyclomaticComplexity">
            <property name="max" value="15"/>
        </module>
        <module name="MethodLength">
            <property name="max" value="80"/>
        </module>
        <module name="ParameterNumber">
            <property name="max" value="8"/>
        </module>

        <!-- ── Annotations ───────────────────────────────────────────── -->
        <module name="MissingOverride"/>
        <module name="SuppressWarningsHolder"/>
    </module>

    <!-- Allow @SuppressWarnings("checkstyle:...") to silence specific rules
         with documented justification -->
    <module name="SuppressWarningsFilter"/>

    <!-- ── Line length ─────────────────────────────────────────────────────── -->
    <!-- Must be a direct child of Checker (not TreeWalker) in Checkstyle 10+.
         120 chars — wider than Google's 100 to accommodate long type names
         common in Spring Security and Jakarta Validation APIs. -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>
</module>
