<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter for ProfitFlow.

  Rationale:
  - EI_EXPOSE_REP / EI_EXPOSE_REP2: Java Records expose internal arrays by
    reference. The domains use immutable types (Money, ResourceCost) so this
    is safe; suppressed to reduce noise.
  - MS_SHOULD_BE_FINAL: Spring @Bean methods flagged unnecessarily.
  - EI_EXPOSE_REP / EI_EXPOSE_REP2 on JPA entities: association graph is managed by
    Hibernate; getters/setters match the persistence contract.
  - EI_EXPOSE_REP2 on Spring constructor injection: ports, filters, and framework
    singletons (ObjectMapper, MeterRegistry, RedisTemplate) are thread-safe and not
    mutated by application code after wiring.

  Do NOT add suppressions for real bugs.  Every suppression must have a
  business justification comment linking to an ADR or a ticket.
-->
<FindBugsFilter>
    <!-- Records expose internal state by design; all domain records use
         immutable value types so the reference exposure is safe. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Class name="~com\.profitflow\.domain\..*"/>
    </Match>

    <!-- Spring AOP proxy classes are generated at runtime; SpotBugs cannot
         reason about them correctly and produces false-positive NP_ warnings. -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
        <Class name="~com\.profitflow\.security\.AuditAspect"/>
    </Match>

    <!-- JPA entity associations: SpotBugs cannot see Hibernate immutability guarantees. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Class name="~com\.profitflow\.adapter\.out\.persistence\.entity\..*"/>
    </Match>

    <!-- Constructor-injected Spring collaborators (ports, filters, ObjectMapper, etc.). -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Or>
            <Class name="~com\.profitflow\.adapter\..*"/>
            <Class name="~com\.profitflow\.application\.service\..*"/>
            <Class name="~com\.profitflow\.infrastructure\..*"/>
            <Class name="~com\.profitflow\.security\..*"/>
        </Or>
    </Match>
</FindBugsFilter>
