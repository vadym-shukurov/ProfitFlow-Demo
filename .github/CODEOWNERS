# ── CODEOWNERS ────────────────────────────────────────────────────────────────
#
# Defines who must review changes to specific parts of the codebase.
# All listed owners are required reviewers; PRs cannot merge without approval.
#
# Finance application ownership model:
#   - Domain model (allocation engine, money):  reviewed by Finance Engineer + Principal
#   - Security layer:                           reviewed by Security Lead
#   - CI/CD pipeline:                          reviewed by DevOps Lead
#   - Database migrations:                     reviewed by DBA / Principal
#
# Syntax: pattern  @owner1 @owner2 @team
# Last matching pattern takes precedence.
#
# IMPORTANT: Replace @your-username with real GitHub usernames/teams.

# Default: all files require a review from a team lead
*                                     @your-org/engineering

# ── Domain layer ─────────────────────────────────────────────────────────────
# Core allocation engine — critical business logic; requires Principal review
/backend/src/main/java/com/profitflow/domain/                @your-org/principal-engineers
/backend/src/test/java/com/profitflow/domain/                @your-org/principal-engineers

# ── Security layer ────────────────────────────────────────────────────────────
# Any change to auth, JWT, RBAC, rate limiting, or audit logging
/backend/src/main/java/com/profitflow/security/              @your-org/security
/backend/src/main/java/com/profitflow/adapter/in/web/AuthController.java  @your-org/security
/backend/src/main/resources/certs/                           @your-org/security

# ── Database migrations ───────────────────────────────────────────────────────
# Migrations are irreversible in production — require DBA and Principal review
/backend/src/main/resources/db/migration/                    @your-org/principal-engineers @your-org/dba

# ── Infrastructure & CI/CD ────────────────────────────────────────────────────
/.github/                                                     @your-org/devops
/docker-compose.yml                                           @your-org/devops
/backend/Dockerfile                                           @your-org/devops
/frontend/Dockerfile                                          @your-org/devops
/monitoring/                                                  @your-org/devops

# ── Dependency manifests (vulnerability surface) ──────────────────────────────
/backend/pom.xml                                              @your-org/security @your-org/principal-engineers
/frontend/package.json                                        @your-org/security
/frontend/package-lock.json                                   @your-org/security
